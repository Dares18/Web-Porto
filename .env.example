APP_NAME="Web-Porto Daffa ATS"
APP_VERSION="6.0"
ENVIRONMENT="production"

# Kredensial Layanan Kontak & Analitik (Opsional)
CONTACT_API_ENDPOINT=""
EMAILJS_SERVICE_ID=""
EMAILJS_TEMPLATE_ID=""
EMAILJS_PUBLIC_KEY=""
